OLLAMA_EMBED_MODEL=snowflake-arctic-embed2:latest
OLLAMA_EMBEDDING_DIMS=1024
OLLAMA_MAX_PASSAGES=3
OLLAMA_PASSAGE_CHARS=480
OLLAMA_NUM_PREDICT=512
