YANDEX_API_KEY=
YANDEX_IAM_TOKEN=
YANDEX_FOLDER_ID=
YANDEX_MODEL=yandexgpt-lite
YANDEX_EMBED_DOC_MODEL=text-embeddings-doc-v2
YANDEX_EMBED_QUERY_MODEL=text-search-query
EMBEDDING_DIMS=256
MOCK_YANDEX=false

DEFAULT_ML_PROVIDER=cloud
